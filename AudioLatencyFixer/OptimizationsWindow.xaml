<Window x:Class="AudioLatencyFixer.OptimizationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Optimizations"
        Height="300"
        Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Optimizations"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <!-- BASIC -->
            <CheckBox x:Name="PriorityBoostCheck"
                      Content="Boost Process Priority"
                      IsChecked="True"/>

            <CheckBox x:Name="ThreadBoostCheck"
                      Content="Boost Thread Priority"
                      IsChecked="True"/>

            <CheckBox x:Name="DuckingCheck"
                      Content="Disable Audio Ducking"
                      IsChecked="True"/>

            <!-- ADVANCED -->
            <TextBlock Text="Advanced"
                       Margin="0,15,0,5"
                       FontWeight="Bold"/>

            <CheckBox x:Name="AdvancedModeCheck"
                      Content="Enable Advanced Mode (Experimental)"/>

            <Button Content="Apply"
                    Margin="0,15,0,0"
                    Height="30"
                    Click="Apply_Click"/>

        </StackPanel>
    </Grid>
</Window>