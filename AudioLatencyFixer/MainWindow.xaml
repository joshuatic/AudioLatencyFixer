<Window x:Class="AudioLatencyFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Latency Fixer"
        Height="300"
        Width="30"
        MinHeight="350"
        MinWidth="350"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                Property="Background"
                                Value="#E5F1FB"/>
                            </Trigger>

                            <!-- Click -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                Property="Background"
                                Value="#CCE4F7"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <StackPanel>
            <Grid x:Name="MainView">
                <StackPanel Margin="20">

                    <TextBlock Text="Audio Latency Fixer"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

                    <TextBlock x:Name="LatencyText"
                       Text="Latency: Unknown"
                       Margin="0,0,0,10"/>

                    <TextBlock x:Name="DeviceText"
                       Text="Device: Unknown"
                       Margin="0,0,0,20"/>

                    <Button x:Name="LatencyFixButton"
                    Content="Enable Latency Fix"
                    Height="35"
                    Margin="0,0,0,10"
                    Click="LatencyFixButton_Click"/>

                    <Button Content="Run Latency Test"
                    Height="35"
                    Margin="0,0,0,10"
                    Click="RunLatencyTest_Click"/>

                    <Button Content="Optimizations"
                    Height="35"
                    Click="OpenOptimizations_Click"/>

                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>